{
  "name": "cloud-vault",
  "private": true,
  "version": "0.1.0",
  "description": "Cloudflare-based bookkeeping app with a Vue web client and Hono Worker API.",
  "workspaces": [
    "frontend",
    "worker"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:worker": "npm --workspace worker run dev",
    "build": "npm --workspaces run build",
    "typecheck": "npm --workspaces run typecheck",
    "lint": "npm --workspaces run lint --if-present",
    "test:visual": "playwright test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
